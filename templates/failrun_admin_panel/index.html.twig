<script>
    /**
     * Cambia entre pestañas del panel
     * @param {string} name - Nombre de la pestaña (users, clips, games, etc.)
     */
    function switchTab(event, name) {
        // Oculta todas las pestañas
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        
        // Muestra la pestaña seleccionada y marca el botón como activo
        document.getElementById('tab-' + name).classList.add('active');
        event.target.classList.add('active');
    }

    /**
     * Filtra la tabla de usuarios combinando búsqueda de texto y filtro de rol
     */
    function filterUsersTable() {
        const query = document.getElementById('users-search').value.toLowerCase();
        const colIndex = document.getElementById('users-col').value;
        const roleFilter = document.getElementById('users-role-filter').value;

        const table = document.getElementById('users-table');
        const rows = table.querySelectorAll('tbody tr');
        let visible = 0;

        rows.forEach(row => {
            const cells = row.querySelectorAll('td');
            const rowRole = row.getAttribute('data-role') || '';

            // Filtro de texto
            let textMatch = true;
            if (query) {
                if (colIndex === '' || colIndex === undefined) {
                    textMatch = Array.from(cells).some(td => td.textContent.toLowerCase().includes(query));
                } else {
                    textMatch = cells[parseInt(colIndex)]?.textContent.toLowerCase().includes(query) ?? false;
                }
            }

            // Filtro de rol
            const roleMatch = roleFilter === '' || rowRole === roleFilter;

            const show = textMatch && roleMatch;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        const countEl = document.getElementById('users-count');
        if (countEl) countEl.textContent = visible + ' registros';
    }

    /**
     * Filtra las filas de una tabla según el valor de búsqueda
     * @param {string} tableId - ID de la tabla
     * @param {string} query - Texto a buscar
     * @param {string} colIndex - Índice de columna (vacío para todas)
     */
    function filterTable(tableId, query, colIndex) {
        const table = document.getElementById(tableId);
        const rows = table.querySelectorAll('tbody tr');
        const q = query.toLowerCase();
        let visible = 0;

        rows.forEach(row => {
            const cells = row.querySelectorAll('td');
            let match = false;

            if (colIndex === '' || colIndex === undefined) {
                match = Array.from(cells).some(td => td.textContent.toLowerCase().includes(q));
            } else {
                match = cells[parseInt(colIndex)]?.textContent.toLowerCase().includes(q);
            }

            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        // Actualiza el contador de registros
        const countId = tableId.replace('-table', '').replace('-', '_') + '-count';
        const countEl = document.getElementById(countId);
        if (countEl) countEl.textContent = visible + ' registros';
    }

    /**
     * Ordena una tabla por una columna específica
     * @param {string} tableId - ID de la tabla
     * @param {number} colIndex - Índice de columna
     */
    function sortTable(tableId, colIndex) {
        const table = document.getElementById(tableId);
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const th = table.querySelectorAll('thead th')[colIndex];
        const asc = !th.classList.contains('sort-asc');

        // Limpia indicadores de orden previos
        table.querySelectorAll('thead th').forEach(t => t.classList.remove('sort-asc', 'sort-desc'));
        th.classList.add(asc ? 'sort-asc' : 'sort-desc');

        // Ordena las filas
        rows.sort((a, b) => {
            const aText = a.querySelectorAll('td')[colIndex]?.textContent.trim() ?? '';
            const bText = b.querySelectorAll('td')[colIndex]?.textContent.trim() ?? '';
            const aNum = parseFloat(aText);
            const bNum = parseFloat(bText);

            if (!isNaN(aNum) && !isNaN(bNum)) return asc ? aNum - bNum : bNum - aNum;
            return asc ? aText.localeCompare(bText) : bText.localeCompare(aText);
        });

        // Reinserta las filas ordenadas
        rows.forEach(r => tbody.appendChild(r));
    }

    /**
     * Abre un modal
     * @param {string} modalId - ID del modal
     * @param {string} mode - 'new' para crear, 'edit' para editar
     */
    function openModal(modalId, mode = 'new') {
        const modal = document.getElementById(modalId);
        modal.classList.add('active');

        // Limpia el formulario si es modo "new"
        if (mode === 'new') {
            const form = modal.querySelector('form');
            if (form) form.reset();
            
            // Actualiza el título del modal
            const titleEl = modal.querySelector('.modal-header h2');
            if (titleEl) {
                const entityName = modalId.replace('modal-', '').replace('-form', '');
                const titles = {
                    'user': 'Nuevo Usuario',
                    'clip': 'Nuevo Clip',
                    'game': 'Nuevo Juego',
                    'mark': 'Nueva Marca',
                    'mark-type': 'Nuevo Tipo de Marca',
                    'user-rate': 'Nueva Valoración',
                    'user-request': 'Nueva Solicitud'
                };
                titleEl.textContent = titles[entityName] || 'Nuevo Registro';
            }
        }
    }

    /**
     * Cierra un modal
     * @param {string} modalId - ID del modal
     */
    function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        modal.classList.remove('active');
    }

    /**
     * Carga los datos de una entidad en el modal para editar
     * @param {string} entity - Nombre de la entidad
     * @param {number} id - ID del registro
     * @param {string} modalId - ID del modal
     */
    function editEntity(entity, id, modalId) {
        fetch(`/failrun/admin/entity/${entity}/${id}`)
            .then(response => response.json())
            .then(data => {
                const modal = document.getElementById(modalId);
                const form = modal.querySelector('form');
                const titleEl = modal.querySelector('.modal-header h2');

                // Actualiza el título
                if (titleEl) titleEl.textContent = 'Editar Registro';

                // Llena los campos del formulario
                for (let key in data) {
                    const field = form.elements[key];
                    if (!field) continue;

                    if (key === 'roles' && form.elements['role']) {
                        if (Array.isArray(data.roles) && data.roles.includes('ROLE_ADMIN')) {
                            form.elements['role'].value = 'ROLE_ADMIN';
                        } else if (Array.isArray(data.roles) && data.roles.includes('ROLE_MODERATOR')) {
                            form.elements['role'].value = 'ROLE_MODERATOR';
                        } else {
                            form.elements['role'].value = 'ROLE_USER';
                        }
                        continue;
                    }

                    field.value = data[key] ?? '';
                }

                openModal(modalId, 'edit');
            })
            .catch(() => showToast('Error al cargar el registro', 'error'));
    }

    /**
     * Elimina un registro con confirmación
     * @param {string} entity - Nombre de la entidad
     * @param {number} id - ID del registro
     * @param {string} tableId - ID de la tabla
     */
    function deleteEntity(entity, id, tableId) {
        if (!confirm('¿Estás seguro de que deseas eliminar este registro?')) return;

        fetch(`/failrun/admin/entity/${entity}/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    // Recarga la tabla (simple refresh de página)
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.error || 'Error al eliminar', 'error');
                }
            })
            .catch(() => showToast('Error en la solicitud', 'error'));
    }

    /**
     * Envía el formulario para crear/actualizar un registro
     * @param {Event} event - Evento del formulario
     * @param {string} entity - Nombre de la entidad
     * @param {string} tableId - ID de la tabla
     */
    function submitForm(event, entity, tableId) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        // Determina si es crear o actualizar
        const isUpdate = data.id && data.id !== '';
        const method = isUpdate ? 'PUT' : 'POST';

        fetch(`/failrun/admin/entity/${entity}`, {
            method: method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    // Cierra el modal y recarga la tabla
                    const modal = form.closest('.modal');
                    closeModal(modal.id);
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.error || 'Error al guardar', 'error');
                }
            })
            .catch(() => showToast('Error en la solicitud', 'error'));
    }

    /**
     * Muestra una notificación toast
     * @param {string} message - Mensaje a mostrar
     * @param {string} type - 'success' o 'error'
     */
    function showToast(message, type = 'success') {
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        toast.textContent = message;
        document.body.appendChild(toast);

        // Elimina el toast después de 3 segundos
        setTimeout(() => {
            toast.style.animation = 'slideInToast 0.3s reverse';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    /**
     * Carga los detalles de una entidad en un modal de vista
     * @param {string} entity - Nombre de la entidad
     * @param {number} id - ID del registro
     * @param {string} modalId - ID del modal
     */
    function viewDetails(entity, id, modalId) {
        fetch(`/failrun/admin/entity/${entity}/${id}`)
            .then(response => response.json())
            .then(data => {
                const modal = document.getElementById(modalId);
                
                // Mapea los datos según la entidad
                if (entity === 'user_requests') {
                    document.getElementById('req-view-id').textContent = data.id;
                    document.getElementById('req-view-title').textContent = data.titleRequest || '—';
                    document.getElementById('req-view-description').textContent = data.descriptionRequest || '—';
                    document.getElementById('req-view-date').textContent = data.dateRequest ? new Date(data.dateRequest).toLocaleDateString('es-ES') : '—';
                    const statusText = data.statusRequest === 0 ? 'Pendiente' : (data.statusRequest === 1 ? 'Aceptado' : 'Rechazado');
                    document.getElementById('req-view-status').innerHTML = `<span class="badge badge-${data.statusRequest === 0 ? 'pending' : (data.statusRequest === 1 ? 'accepted' : 'rejected')}">${statusText}</span>`;
                    document.getElementById('req-view-user').textContent = data.userId?.username || '—';
                }
                else if (entity === 'clips') {
                    document.getElementById('clip-view-id').textContent = data.id;
                    document.getElementById('clip-view-title').textContent = data.clipTitle || '—';
                    document.getElementById('clip-view-description').textContent = data.clipDescription || '—';
                    document.getElementById('clip-view-date').textContent = data.clipDate ? new Date(data.clipDate).toLocaleDateString('es-ES') : '—';
                    const statusText = data.clipStatus === 0 ? 'Pendiente' : (data.clipStatus === 1 ? 'Aceptado' : 'Rechazado');
                    document.getElementById('clip-view-status').innerHTML = `<span class="badge badge-${data.clipStatus === 0 ? 'pending' : (data.clipStatus === 1 ? 'accepted' : 'rejected')}">${statusText}</span>`;
                    document.getElementById('clip-view-user').textContent = data.userId?.username || '—';
                    document.getElementById('clip-view-game').textContent = data.gameId?.gameName || '—';
                }
                else if (entity === 'games') {
                    document.getElementById('game-view-id').textContent = data.id;
                    document.getElementById('game-view-name').textContent = data.gameName || '—';
                    document.getElementById('game-view-description').textContent = data.gameDescription || '—';
                    document.getElementById('game-view-cover').textContent = data.coverImg || '—';
                }
                else if (entity === 'marks') {
                    document.getElementById('mark-view-id').textContent = data.id;
                    document.getElementById('mark-view-rate').textContent = data.markRate || '—';
                    document.getElementById('mark-view-date').textContent = data.markDate ? new Date(data.markDate).toLocaleDateString('es-ES') : '—';
                    document.getElementById('mark-view-clip').textContent = data.clipId?.clipTitle || '—';
                    document.getElementById('mark-view-type').textContent = data.idMarkType?.markName || '—';
                }
                else if (entity === 'mark_types') {
                    document.getElementById('mark-type-view-id').textContent = data.id;
                    document.getElementById('mark-type-view-name').textContent = data.markName || '—';
                    document.getElementById('mark-type-view-description').textContent = data.markDescription || '—';
                    document.getElementById('mark-type-view-logo').textContent = data.markLogoUrl || '—';
                }
                else if (entity === 'user_rates') {
                    document.getElementById('user-rate-view-id').textContent = data.id;
                    document.getElementById('user-rate-view-rate').textContent = data.rate || '—';
                    document.getElementById('user-rate-view-comment').textContent = data.userComment || '—';
                    document.getElementById('user-rate-view-date').textContent = data.rateDate ? new Date(data.rateDate).toLocaleDateString('es-ES') : '—';
                    document.getElementById('user-rate-view-user').textContent = data.userId?.username || '—';
                    document.getElementById('user-rate-view-clip').textContent = data.clipId?.clipTitle || '—';
                }
                
                // Abre el modal
                modal.classList.add('active');
            })
            .catch(() => showToast('Error al cargar los detalles', 'error'));
    }

    // Cierra modales al hacer clic fuera de ellos
    document.querySelectorAll('.modal').forEach(modal => {
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal(modal.id);
        });
    });
</script>

</body>
</html>