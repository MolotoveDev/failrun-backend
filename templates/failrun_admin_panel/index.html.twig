<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Failrun — Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --red: #FF2D55;
            --red-dark: #CF2949;
            --bg: #333335;
            --surface: #41414A;
            --surface2: #2a2a30;
            --text: #ffffff;
            --text-muted: rgba(255,255,255,0.4);
            --border: rgba(255,255,255,0.07);
        }

        body {
            font-family: "Montserrat", sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAV */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            height: 60px;
            background-color: var(--red);
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-brand {
            font-size: 1.5rem;
            font-weight: 900;
            letter-spacing: -1px;
        }

        .nav-brand span { opacity: 0.7; font-weight: 600; font-size: 0.85rem; letter-spacing: 2px; margin-left: 0.5rem; vertical-align: middle; }

        .nav-logout {
            background: rgba(0,0,0,0.2);
            color: white;
            border: 1px solid rgba(255,255,255,0.2);
            padding: 0.4rem 1.2rem;
            border-radius: 8px;
            font-family: "Montserrat", sans-serif;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1px;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
        }

        .nav-logout:hover { background: rgba(0,0,0,0.4); }

        /* MAIN */
        main { padding: 2rem; flex: 1; }

        /* TABS */
        .tabs {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .tab-btn {
            background: var(--surface);
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: 0.6rem 1.4rem;
            border-radius: 10px;
            font-family: "Montserrat", sans-serif;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

        .tab-btn.active {
            background: var(--red);
            color: white;
            border-color: var(--red);
        }

        /* TAB CONTENT */
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* TABLE WRAPPER */
        .table-wrapper {
            background: var(--surface);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        }

        .table-toolbar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.2rem;
            flex-wrap: wrap;
        }

        .search-input {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.6rem 1rem;
            color: var(--text);
            font-family: "Montserrat", sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            outline: none;
            width: 280px;
            transition: border-color 0.2s;
        }

        .search-input:focus { border-color: var(--red); }
        .search-input::placeholder { color: var(--text-muted); font-weight: 400; }

        .filter-select {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.6rem 1rem;
            color: var(--text);
            font-family: "Montserrat", sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            outline: none;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .filter-select:focus { border-color: var(--red); }

        .row-count {
            margin-left: auto;
            color: var(--text-muted);
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* TABLE */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .data-table thead th {
            text-align: left;
            padding: 0.75rem 1rem;
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.7rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }

        .data-table thead th:hover { color: var(--text); }
        .data-table thead th.sort-asc::after { content: " ↑"; color: var(--red); }
        .data-table thead th.sort-desc::after { content: " ↓"; color: var(--red); }

        .data-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
        }

        .data-table tbody tr:hover { background: rgba(255,255,255,0.03); }
        .data-table tbody tr:last-child { border-bottom: none; }

        .data-table tbody td {
            padding: 0.75rem 1rem;
            color: var(--text);
            font-weight: 500;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .badge-admin { background: rgba(255,45,85,0.2); color: var(--red); }
        .badge-moderator { background: rgba(175,82,222,0.2); color: #AF52DE; }
        .badge-user { background: rgba(255,255,255,0.08); color: var(--text-muted); }
        .badge-pending { background: rgba(255,204,0,0.15); color: #FFCC00; }
        .badge-accepted { background: rgba(52,199,89,0.15); color: #34C759; }
        .badge-rejected { background: rgba(255,45,85,0.15); color: var(--red); }

        .no-results {
            text-align: center;
            padding: 3rem;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .table-scroll { overflow-x: auto; }

        /* BOTONES DE ACCIÓN */
        .btn {
            padding: 0.35rem 0.8rem;
            border: none;
            border-radius: 6px;
            font-family: "Montserrat", sans-serif;
            font-weight: 700;
            font-size: 0.65rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            white-space: nowrap;
        }

        .btn-view {
            background: rgba(10,132,255,0.15);
            color: #0A84FF;
            border: 1px solid rgba(10,132,255,0.3);
            text-decoration: none;
        }

        .btn-view:hover {
            background: rgba(10,132,255,0.25);
            border-color: #0A84FF;
        }

        .btn-edit {
            background: rgba(52,199,89,0.15);
            color: #34C759;
            border: 1px solid rgba(52,199,89,0.3);
        }

        .btn-edit:hover {
            background: rgba(52,199,89,0.25);
            border-color: #34C759;
        }

        .btn-delete {
            background: rgba(255,45,85,0.15);
            color: var(--red);
            border: 1px solid rgba(255,45,85,0.3);
        }

        .btn-delete:hover {
            background: rgba(255,45,85,0.25);
            border-color: var(--red);
        }

        .btn-add {
            background: var(--red);
            color: white;
            border: 1px solid var(--red);
            margin-bottom: 1rem;
        }

        .btn-add:hover {
            background: var(--red-dark);
            border-color: var(--red-dark);
        }

        .btn-primary {
            background: var(--red);
            color: white;
            border: 1px solid var(--red);
        }

        .btn-primary:hover {
            background: var(--red-dark);
        }

        .btn-secondary {
            background: var(--surface2);
            color: var(--text-muted);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--surface);
            color: var(--text);
        }

        /* MODAL */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            animation: fadeInModal 0.2s;
        }

        .modal.active {
            display: flex;
        }

        @keyframes fadeInModal {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: var(--surface);
            border-radius: 16px;
            padding: 2rem;
            width: 90%;
            max-width: 500px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            animation: slideInModal 0.2s;
        }

        @keyframes slideInModal {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--border);
            padding-bottom: 1rem;
        }

        .modal-header h2 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 700;
        }

        .modal-close {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.5rem;
            cursor: pointer;
            line-height: 1;
            transition: color 0.2s;
        }

        .modal-close:hover {
            color: var(--text);
        }

        .modal-body {
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.2rem;
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            color: var(--text-muted);
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 0.4rem;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.6rem 1rem;
            color: var(--text);
            font-family: "Montserrat", sans-serif;
            font-size: 0.85rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--red);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }

        .form-help {
            margin-top: 0.35rem;
            color: var(--text-muted);
            font-size: 0.72rem;
        }

        .modal-footer {
            display: flex;
            gap: 0.8rem;
            justify-content: flex-end;
        }

        /* TOAST DE NOTIFICACIÓN */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            padding: 1rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.85rem;
            animation: slideInToast 0.3s;
            z-index: 2000;
        }

        @keyframes slideInToast {
            from { transform: translateX(400px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .toast.success {
            background: rgba(52,199,89,0.2);
            color: #34C759;
            border: 1px solid rgba(52,199,89,0.3);
        }

        .toast.error {
            background: rgba(255,45,85,0.2);
            color: var(--red);
            border: 1px solid rgba(255,45,85,0.3);
        }

        .action-cell {
            display: flex;
            gap: 0.5rem;
        }

        /* RESPONSIVE DESIGN */
        @media (max-width: 1024px) {
            main { padding: 1.5rem; }
            
            .table-toolbar {
                flex-direction: column;
                align-items: stretch;
                gap: 0.8rem;
            }
            
            .search-input {
                width: 100%;
            }
            
            .filter-select {
                width: 100%;
            }
            
            .row-count {
                margin-left: 0;
                text-align: center;
            }
            
            .data-table tbody td {
                max-width: 150px;
                font-size: 0.75rem;
                padding: 0.5rem;
            }
            
            .data-table thead th {
                padding: 0.5rem;
                font-size: 0.65rem;
            }
            
            .modal-content {
                width: 95%;
                padding: 1.5rem;
                max-height: 90vh;
                overflow-y: auto;
            }
        }

        @media (max-width: 768px) {
            nav {
                padding: 0 1rem;
                height: 50px;
            }
            
            .nav-brand {
                font-size: 1.1rem;
            }
            
            .nav-brand span {
                display: none;
            }
            
            .nav-logout {
                padding: 0.3rem 0.8rem;
                font-size: 0.7rem;
            }
            
            main {
                padding: 1rem;
            }
            
            .tabs {
                gap: 0.3rem;
                margin-bottom: 1rem;
            }
            
            .tab-btn {
                padding: 0.5rem 0.8rem;
                font-size: 0.65rem;
                letter-spacing: 0.5px;
                flex: 1;
                min-width: 60px;
                text-align: center;
            }
            
            .table-wrapper {
                padding: 1rem;
                border-radius: 12px;
            }
            
            .btn-add {
                width: 100%;
                margin-bottom: 0.8rem;
                justify-content: center;
            }
            
            .table-toolbar {
                flex-direction: column;
                gap: 0.6rem;
                margin-bottom: 1rem;
            }
            
            .search-input {
                width: 100%;
                padding: 0.5rem;
                font-size: 0.8rem;
            }
            
            .filter-select {
                width: 100%;
                padding: 0.5rem;
                font-size: 0.8rem;
            }
            
            .row-count {
                font-size: 0.75rem;
                text-align: center;
                margin-left: 0;
            }
            
            .data-table {
                font-size: 0.75rem;
            }
            
            .data-table thead th {
                padding: 0.4rem;
                font-size: 0.6rem;
                white-space: normal;
            }
            
            .data-table tbody td {
                padding: 0.4rem;
                max-width: 120px;
                font-size: 0.7rem;
            }
            
            .btn {
                padding: 0.25rem 0.5rem;
                font-size: 0.6rem;
                gap: 0.2rem;
            }
            
            .action-cell {
                flex-direction: column;
                gap: 0.3rem;
                width: 100%;
            }
            
            .btn-view, .btn-edit, .btn-delete {
                width: 100%;
                justify-content: center;
                font-size: 0.55rem;
            }
            
            .badge {
                padding: 0.15rem 0.4rem;
                font-size: 0.6rem;
            }
            
            .modal-content {
                width: 95%;
                max-width: 90vw;
                padding: 1rem;
                max-height: 85vh;
                overflow-y: auto;
                border-radius: 12px;
            }
            
            .modal-header {
                margin-bottom: 1rem;
                padding-bottom: 0.75rem;
            }
            
            .modal-header h2 {
                font-size: 1rem;
            }
            
            .form-group {
                margin-bottom: 0.8rem;
            }
            
            .form-group label {
                font-size: 0.65rem;
            }
            
            .form-group input,
            .form-group select,
            .form-group textarea {
                padding: 0.5rem;
                font-size: 0.8rem;
            }
            
            .form-help {
                font-size: 0.65rem;
            }
            
            .modal-footer {
                gap: 0.6rem;
                flex-wrap: wrap;
            }
            
            .modal-footer .btn {
                flex: 1;
                min-width: 100px;
                justify-content: center;
            }
            
            .toast {
                bottom: 1rem;
                right: 1rem;
                left: 1rem;
                padding: 0.8rem 1rem;
                font-size: 0.8rem;
            }
        }

        @media (max-width: 480px) {
            :root {
                font-size: 14px;
            }
            
            nav {
                height: 45px;
                padding: 0 0.75rem;
            }
            
            .nav-brand {
                font-size: 0.95rem;
            }
            
            .nav-logout {
                padding: 0.25rem 0.6rem;
                font-size: 0.65rem;
            }
            
            main {
                padding: 0.75rem;
            }
            
            .tabs {
                gap: 0.2rem;
                margin-bottom: 0.8rem;
            }
            
            .tab-btn {
                padding: 0.4rem 0.6rem;
                font-size: 0.6rem;
                letter-spacing: 0px;
            }
            
            .table-wrapper {
                padding: 0.75rem;
            }
            
            .btn-add {
                padding: 0.3rem 0.6rem;
                font-size: 0.6rem;
            }
            
            .data-table {
                font-size: 0.7rem;
            }
            
            .data-table thead th {
                padding: 0.3rem;
                font-size: 0.55rem;
            }
            
            .data-table tbody td {
                padding: 0.3rem;
                max-width: 100px;
                font-size: 0.65rem;
            }
            
            .modal-content {
                width: 98%;
                padding: 0.75rem;
            }
            
            .modal-header h2 {
                font-size: 0.95rem;
            }
            
            .modal-footer .btn {
                min-width: 80px;
            }
        }
    </style>
</head>
<body>

<nav>
    <div class="nav-brand">FAILRUN <span>ADMIN PANEL</span></div>
    <a href="{{ path('app_failrun_admin_logout') }}" class="nav-logout">CERRAR SESIÓN</a>
</nav>

<main>
    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab(event, 'users')">Usuarios</button>
        <button class="tab-btn" onclick="switchTab(event, 'clips')">Clips</button>
        <button class="tab-btn" onclick="switchTab(event, 'games')">Juegos</button>
        <button class="tab-btn" onclick="switchTab(event, 'marks')">Marcas</button>
        <button class="tab-btn" onclick="switchTab(event, 'mark_types')">Tipos de Marca</button>
        <button class="tab-btn" onclick="switchTab(event, 'user_rates')">Valoraciones</button>
        <button class="tab-btn" onclick="switchTab(event, 'user_requests')">Solicitudes</button>
    </div>

    {# USERS #}
    <div class="tab-panel active" id="tab-users">
        <div class="table-wrapper">
            <button class="btn btn-add" onclick="openModal('modal-user-form', 'new')">+ Añadir Usuario</button>
            <div class="table-toolbar">
                <input class="search-input" type="text" id="users-search" placeholder="Buscar..." oninput="filterUsersTable()">
                <select class="filter-select" id="users-col" onchange="filterUsersTable()">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Username</option>
                    <option value="2">Email</option>
                    <option value="4">Fecha registro</option>
                </select>
                <select class="filter-select" id="users-role-filter" onchange="filterUsersTable()">
                    <option value="">Todos los roles</option>
                    <option value="ADMIN">Administrador</option>
                    <option value="MODERATOR">Moderador</option>
                    <option value="USER">Usuario</option>
                </select>
                <span class="row-count" id="users-count">{{ users|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="users-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('users-table',0)">ID</th>
                            <th onclick="sortTable('users-table',1)">Username</th>
                            <th onclick="sortTable('users-table',2)">Email</th>
                            <th onclick="sortTable('users-table',3)">Rol</th>
                            <th onclick="sortTable('users-table',4)">Registro</th>
                            <th onclick="sortTable('users-table',5)">Foto perfil</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr data-role="{{ 'ROLE_ADMIN' in user.roles ? 'ADMIN' : ('ROLE_MODERATOR' in user.roles ? 'MODERATOR' : 'USER') }}">
                            <td>{{ user.id }}</td>
                            <td>{{ user.username }}</td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="badge badge-admin">ADMIN</span>
                                {% elseif 'ROLE_MODERATOR' in user.roles %}
                                    <span class="badge badge-moderator">MODERATOR</span>
                                {% else %}
                                    <span class="badge badge-user">USER</span>
                                {% endif %}
                            </td>
                            <td>{{ user.registerDate ? user.registerDate|date('d/m/Y') : '—' }}</td>
                            <td>{{ user.profilePic ?? '—' }}</td>
                            <td>
                                <div class="action-cell">
                                    <button class="btn btn-edit" onclick="editEntity('users', {{ user.id }}, 'modal-user-form')">Editar</button>
                                    <button class="btn btn-delete" onclick="deleteEntity('users', {{ user.id }}, 'users-table')">Eliminar</button>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="7" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# CLIPS #}
    <div class="tab-panel" id="tab-clips">
        <div class="table-wrapper">
            <button class="btn btn-add" onclick="openModal('modal-clip-form', 'new')">+ Añadir Clip</button>
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('clips-table', this.value, document.getElementById('clips-col').value)">
                <select class="filter-select" id="clips-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Título</option>
                    <option value="2">Estado</option>
                </select>
                <span class="row-count" id="clips-count">{{ clips|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="clips-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('clips-table',0)">ID</th>
                            <th onclick="sortTable('clips-table',1)">Título</th>
                            <th onclick="sortTable('clips-table',2)">Descripción</th>
                            <th onclick="sortTable('clips-table',3)">Fecha</th>
                            <th onclick="sortTable('clips-table',4)">Estado</th>
                            <th onclick="sortTable('clips-table',5)">Usuario</th>
