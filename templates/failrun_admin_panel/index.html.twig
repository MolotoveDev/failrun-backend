<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Failrun — Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --red: #FF2D55;
            --red-dark: #CF2949;
            --bg: #333335;
            --surface: #41414A;
            --surface2: #2a2a30;
            --text: #ffffff;
            --text-muted: rgba(255,255,255,0.4);
            --border: rgba(255,255,255,0.07);
        }

        body {
            font-family: "Montserrat", sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* NAV */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            height: 60px;
            background-color: var(--red);
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-brand {
            font-size: 1.5rem;
            font-weight: 900;
            letter-spacing: -1px;
        }

        .nav-brand span { opacity: 0.7; font-weight: 600; font-size: 0.85rem; letter-spacing: 2px; margin-left: 0.5rem; vertical-align: middle; }

        .nav-logout {
            background: rgba(0,0,0,0.2);
            color: white;
            border: 1px solid rgba(255,255,255,0.2);
            padding: 0.4rem 1.2rem;
            border-radius: 8px;
            font-family: "Montserrat", sans-serif;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1px;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
        }

        .nav-logout:hover { background: rgba(0,0,0,0.4); }

        /* MAIN */
        main { padding: 2rem; flex: 1; }

        /* TABS */
        .tabs {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .tab-btn {
            background: var(--surface);
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: 0.6rem 1.4rem;
            border-radius: 10px;
            font-family: "Montserrat", sans-serif;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

        .tab-btn.active {
            background: var(--red);
            color: white;
            border-color: var(--red);
        }

        /* TAB CONTENT */
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* TABLE WRAPPER */
        .table-wrapper {
            background: var(--surface);
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        }

        .table-toolbar {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.2rem;
            flex-wrap: wrap;
        }

        .search-input {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.6rem 1rem;
            color: var(--text);
            font-family: "Montserrat", sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            outline: none;
            width: 280px;
            transition: border-color 0.2s;
        }

        .search-input:focus { border-color: var(--red); }
        .search-input::placeholder { color: var(--text-muted); font-weight: 400; }

        .filter-select {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 0.6rem 1rem;
            color: var(--text);
            font-family: "Montserrat", sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            outline: none;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .filter-select:focus { border-color: var(--red); }

        .row-count {
            margin-left: auto;
            color: var(--text-muted);
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* TABLE */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .data-table thead th {
            text-align: left;
            padding: 0.75rem 1rem;
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.7rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }

        .data-table thead th:hover { color: var(--text); }
        .data-table thead th.sort-asc::after { content: " ↑"; color: var(--red); }
        .data-table thead th.sort-desc::after { content: " ↓"; color: var(--red); }

        .data-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
        }

        .data-table tbody tr:hover { background: rgba(255,255,255,0.03); }
        .data-table tbody tr:last-child { border-bottom: none; }

        .data-table tbody td {
            padding: 0.75rem 1rem;
            color: var(--text);
            font-weight: 500;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .badge-admin { background: rgba(255,45,85,0.2); color: var(--red); }
        .badge-user { background: rgba(255,255,255,0.08); color: var(--text-muted); }
        .badge-pending { background: rgba(255,204,0,0.15); color: #FFCC00; }
        .badge-accepted { background: rgba(52,199,89,0.15); color: #34C759; }
        .badge-rejected { background: rgba(255,45,85,0.15); color: var(--red); }

        .no-results {
            text-align: center;
            padding: 3rem;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .table-scroll { overflow-x: auto; }
    </style>
</head>
<body>

<nav>
    <div class="nav-brand">FAILRUN <span>ADMIN PANEL</span></div>
    <a href="{{ path('app_failrun_admin_logout') }}" class="nav-logout">CERRAR SESIÓN</a>
</nav>

<main>
    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('users')">Usuarios</button>
        <button class="tab-btn" onclick="switchTab('clips')">Clips</button>
        <button class="tab-btn" onclick="switchTab('games')">Juegos</button>
        <button class="tab-btn" onclick="switchTab('marks')">Marcas</button>
        <button class="tab-btn" onclick="switchTab('mark_types')">Tipos de Marca</button>
        <button class="tab-btn" onclick="switchTab('user_rates')">Valoraciones</button>
        <button class="tab-btn" onclick="switchTab('user_requests')">Solicitudes</button>
    </div>

    {# USERS #}
    <div class="tab-panel active" id="tab-users">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('users-table', this.value, document.getElementById('users-col').value)">
                <select class="filter-select" id="users-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Username</option>
                    <option value="2">Email</option>
                    <option value="3">Rol</option>
                    <option value="4">Fecha registro</option>
                </select>
                <span class="row-count" id="users-count">{{ users|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="users-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('users-table',0)">ID</th>
                            <th onclick="sortTable('users-table',1)">Username</th>
                            <th onclick="sortTable('users-table',2)">Email</th>
                            <th onclick="sortTable('users-table',3)">Rol</th>
                            <th onclick="sortTable('users-table',4)">Registro</th>
                            <th onclick="sortTable('users-table',5)">Foto perfil</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>{{ user.username }}</td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="badge badge-admin">ADMIN</span>
                                {% else %}
                                    <span class="badge badge-user">USER</span>
                                {% endif %}
                            </td>
                            <td>{{ user.registerDate ? user.registerDate|date('d/m/Y') : '—' }}</td>
                            <td>{{ user.profilePic ?? '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="6" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# CLIPS #}
    <div class="tab-panel" id="tab-clips">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('clips-table', this.value, document.getElementById('clips-col').value)">
                <select class="filter-select" id="clips-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Título</option>
                    <option value="2">Estado</option>
                </select>
                <span class="row-count" id="clips-count">{{ clips|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="clips-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('clips-table',0)">ID</th>
                            <th onclick="sortTable('clips-table',1)">Título</th>
                            <th onclick="sortTable('clips-table',2)">Descripción</th>
                            <th onclick="sortTable('clips-table',3)">Fecha</th>
                            <th onclick="sortTable('clips-table',4)">Estado</th>
                            <th onclick="sortTable('clips-table',5)">Usuario</th>
                            <th onclick="sortTable('clips-table',6)">Juego</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for clip in clips %}
                        <tr>
                            <td>{{ clip.id }}</td>
                            <td>{{ clip.clipTitle }}</td>
                            <td>{{ clip.clipDescription ?? '—' }}</td>
                            <td>{{ clip.clipDate ? clip.clipDate|date('d/m/Y') : '—' }}</td>
                            <td>
                                {% if clip.clipStatus == 0 %}
                                    <span class="badge badge-pending">PENDIENTE</span>
                                {% elseif clip.clipStatus == 1 %}
                                    <span class="badge badge-accepted">ACEPTADO</span>
                                {% else %}
                                    <span class="badge badge-rejected">RECHAZADO</span>
                                {% endif %}
                            </td>
                            <td>{{ clip.userId ? clip.userId.username : '—' }}</td>
                            <td>{{ clip.gameId ? clip.gameId.gameName : '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="7" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# GAMES #}
    <div class="tab-panel" id="tab-games">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('games-table', this.value, document.getElementById('games-col').value)">
                <select class="filter-select" id="games-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Nombre</option>
                </select>
                <span class="row-count" id="games-count">{{ games|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="games-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('games-table',0)">ID</th>
                            <th onclick="sortTable('games-table',1)">Nombre</th>
                            <th onclick="sortTable('games-table',2)">Descripción</th>
                            <th onclick="sortTable('games-table',3)">Cover</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for game in games %}
                        <tr>
                            <td>{{ game.id }}</td>
                            <td>{{ game.gameName }}</td>
                            <td>{{ game.gameDescription ?? '—' }}</td>
                            <td>{{ game.coverImg ?? '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="4" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# MARKS #}
    <div class="tab-panel" id="tab-marks">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('marks-table', this.value, document.getElementById('marks-col').value)">
                <select class="filter-select" id="marks-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Valoración</option>
                </select>
                <span class="row-count" id="marks-count">{{ marks|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="marks-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('marks-table',0)">ID</th>
                            <th onclick="sortTable('marks-table',1)">Valoración</th>
                            <th onclick="sortTable('marks-table',2)">Fecha</th>
                            <th onclick="sortTable('marks-table',3)">Clip</th>
                            <th onclick="sortTable('marks-table',4)">Tipo</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for mark in marks %}
                        <tr>
                            <td>{{ mark.id }}</td>
                            <td>{{ mark.markRate }}</td>
                            <td>{{ mark.markDate ? mark.markDate|date('d/m/Y') : '—' }}</td>
                            <td>{{ mark.clipId ? mark.clipId.clipTitle : '—' }}</td>
                            <td>{{ mark.idMarkType ? mark.idMarkType.markName : '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="5" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# MARK TYPES #}
    <div class="tab-panel" id="tab-mark_types">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('mark-types-table', this.value, document.getElementById('mark-types-col').value)">
                <select class="filter-select" id="mark-types-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Nombre</option>
                </select>
                <span class="row-count" id="mark_types-count">{{ mark_types|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="mark-types-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('mark-types-table',0)">ID</th>
                            <th onclick="sortTable('mark-types-table',1)">Nombre</th>
                            <th onclick="sortTable('mark-types-table',2)">Descripción</th>
                            <th onclick="sortTable('mark-types-table',3)">Logo URL</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for mt in mark_types %}
                        <tr>
                            <td>{{ mt.id }}</td>
                            <td>{{ mt.markName }}</td>
                            <td>{{ mt.markDescription ?? '—' }}</td>
                            <td>{{ mt.markLogoUrl ?? '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="4" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# USER RATES #}
    <div class="tab-panel" id="tab-user_rates">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('user-rates-table', this.value, document.getElementById('user-rates-col').value)">
                <select class="filter-select" id="user-rates-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Valoración</option>
                </select>
                <span class="row-count" id="user_rates-count">{{ user_rates|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="user-rates-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('user-rates-table',0)">ID</th>
                            <th onclick="sortTable('user-rates-table',1)">Valoración</th>
                            <th onclick="sortTable('user-rates-table',2)">Comentario</th>
                            <th onclick="sortTable('user-rates-table',3)">Fecha</th>
                            <th onclick="sortTable('user-rates-table',4)">Usuario</th>
                            <th onclick="sortTable('user-rates-table',5)">Clip</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for rate in user_rates %}
                        <tr>
                            <td>{{ rate.id }}</td>
                            <td>{{ rate.rate }}</td>
                            <td>{{ rate.userComment ?? '—' }}</td>
                            <td>{{ rate.rateDate ? rate.rateDate|date('d/m/Y') : '—' }}</td>
                            <td>{{ rate.userId ? rate.userId.username : '—' }}</td>
                            <td>{{ rate.clipId ? rate.clipId.clipTitle : '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="6" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# USER REQUESTS #}
    <div class="tab-panel" id="tab-user_requests">
        <div class="table-wrapper">
            <div class="table-toolbar">
                <input class="search-input" type="text" placeholder="Buscar..." oninput="filterTable('user-requests-table', this.value, document.getElementById('user-requests-col').value)">
                <select class="filter-select" id="user-requests-col">
                    <option value="">Todas las columnas</option>
                    <option value="0">ID</option>
                    <option value="1">Título</option>
                    <option value="2">Estado</option>
                </select>
                <span class="row-count" id="user_requests-count">{{ user_requests|length }} registros</span>
            </div>
            <div class="table-scroll">
                <table class="data-table" id="user-requests-table">
                    <thead>
                        <tr>
                            <th onclick="sortTable('user-requests-table',0)">ID</th>
                            <th onclick="sortTable('user-requests-table',1)">Título</th>
                            <th onclick="sortTable('user-requests-table',2)">Descripción</th>
                            <th onclick="sortTable('user-requests-table',3)">Fecha</th>
                            <th onclick="sortTable('user-requests-table',4)">Estado</th>
                            <th onclick="sortTable('user-requests-table',5)">Usuario</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for req in user_requests %}
                        <tr>
                            <td>{{ req.id }}</td>
                            <td>{{ req.titleRequest }}</td>
                            <td>{{ req.descriptionRequest }}</td>
                            <td>{{ req.dateRequest ? req.dateRequest|date('d/m/Y') : '—' }}</td>
                            <td>
                                {% if req.statusRequest == 0 %}
                                    <span class="badge badge-pending">PENDIENTE</span>
                                {% elseif req.statusRequest == 1 %}
                                    <span class="badge badge-accepted">ACEPTADO</span>
                                {% else %}
                                    <span class="badge badge-rejected">RECHAZADO</span>
                                {% endif %}
                            </td>
                            <td>{{ req.userId ? req.userId.username : '—' }}</td>
                        </tr>
                        {% else %}
                        <tr><td colspan="6" class="no-results">Sin resultados</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</main>

<script>
    function switchTab(name) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        event.target.classList.add('active');
    }

    function filterTable(tableId, query, colIndex) {
        const table = document.getElementById(tableId);
        const rows = table.querySelectorAll('tbody tr');
        const q = query.toLowerCase();
        let visible = 0;

        rows.forEach(row => {
            const cells = row.querySelectorAll('td');
            let match = false;

            if (colIndex === '' || colIndex === undefined) {
                match = Array.from(cells).some(td => td.textContent.toLowerCase().includes(q));
            } else {
                match = cells[parseInt(colIndex)]?.textContent.toLowerCase().includes(q);
            }

            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        const countId = tableId.replace('-table', '').replace('-', '_') + '-count';
        const countEl = document.getElementById(countId);
        if (countEl) countEl.textContent = visible + ' registros';
    }

    function sortTable(tableId, colIndex) {
        const table = document.getElementById(tableId);
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const th = table.querySelectorAll('thead th')[colIndex];
        const asc = !th.classList.contains('sort-asc');

        table.querySelectorAll('thead th').forEach(t => t.classList.remove('sort-asc', 'sort-desc'));
        th.classList.add(asc ? 'sort-asc' : 'sort-desc');

        rows.sort((a, b) => {
            const aText = a.querySelectorAll('td')[colIndex]?.textContent.trim() ?? '';
            const bText = b.querySelectorAll('td')[colIndex]?.textContent.trim() ?? '';
            const aNum = parseFloat(aText);
            const bNum = parseFloat(bText);

            if (!isNaN(aNum) && !isNaN(bNum)) return asc ? aNum - bNum : bNum - aNum;
            return asc ? aText.localeCompare(bText) : bText.localeCompare(aText);
        });

        rows.forEach(r => tbody.appendChild(r));
    }
</script>

</body>
</html>